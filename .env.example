# Tushare API Token (https://tushare.pro)
TUSHARE_TOKEN=your_tushare_token_here

# LLM API Keys (DeepSeek 必配，OpenAI/Anthropic 可选)
DEEPSEEK_API_KEY=sk-xxx

# LLM 模型选择（全部可选，默认 deepseek-chat，共用 DEEPSEEK_API_KEY）
LLM_RETRIEVAL_MODEL=deepseek-chat       # Phase 3.5: 商业知识检索 (需要 tool calling)
LLM_ANALYSIS_MODEL=deepseek-chat        # Phase 5a: 分析报告 (需要长文写作)
LLM_VALIDATION_MODEL=deepseek-chat      # Phase 5b: 交叉验证 (需要严格 JSON)

# Web 搜索（Phase 3.5 商业检索用）
SEARCH_PROVIDER=tavily                   # tavily | serpapi | none（none=跳过实时搜索）
TAVILY_API_KEY=tvly-xxx

# Data Storage
DATA_DIR=./data_snapshots

# Log Level
LOG_LEVEL=INFO
